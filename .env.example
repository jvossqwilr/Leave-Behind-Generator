# Copy to .env.local for local dev
# Add all of these as Environment Variables in Vercel project settings

# ── REQUIRED ──────────────────────────────────────────────
# Get from console.groq.com (free)
GROQ_API_KEY=your_groq_api_key_here

# Get from notion.so/my-integrations — create a new integration,
# then share each relevant Notion page with it via the "..." menu → "Add connections"
NOTION_TOKEN=your_notion_integration_token_here

# ── NOTION CONTENT MAPPING ────────────────────────────────
# Option A: Database IDs (if your content lives in Notion databases)
# Find the ID in the URL: notion.so/workspace/[DATABASE_ID]?v=...
NOTION_CASE_STUDIES_DB_ID=
NOTION_BATTLE_CARDS_DB_ID=
NOTION_CUSTOMERS_DB_ID=

# Option B: Page IDs (if your content lives in regular Notion pages)
# Find the ID in the URL: notion.so/workspace/PageTitle-[PAGE_ID]
NOTION_CASE_STUDIES_PAGE_ID=
NOTION_BATTLE_CARDS_PAGE_ID=
NOTION_CUSTOMERS_PAGE_ID=

# If none of the above are set, the tool auto-searches your connected
# Notion workspace for pages matching "case studies", "battle cards", "customers"
